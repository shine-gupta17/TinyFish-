# ==============================================
# ChatVerse API - Production Configuration
# ==============================================

# Application Environment
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# URLs
BACKEND_URL=https://api.chatverse.io
FRONTEND_PLATFORM_URL=https://app.chatverse.io

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=https://app.chatverse.io,https://chatverse.io,https://chatverses.web.app

# Security
SECRET_KEY=CHANGE_THIS_TO_STRONG_RANDOM_KEY_32_CHARS_MIN
SESSION_COOKIE_SECURE=True

# Database - Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Instagram API
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=https://api.chatverse.io/instagram/callback

# Facebook API
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=https://api.chatverse.io/auth/facebook/callback

# LinkedIn API
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Vector Database - Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_CHAT_INDEX=chatverse-index

# Storage
CHAT_BUCKET_NAME=chatverse-chat-storage

# Payment - Razorpay (Legacy)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_SECRET=your-razorpay-secret

# Payment - Dodo Payments (Primary)
DODO_PAYMENTS_API_KEY=your-dodo-payments-api-key
DODO_PAYMENTS_ENVIRONMENT=test_mode  # test_mode or live_mode
DODO_BRAND_ID=your-brand-id-here
DODO_WEBHOOK_SECRET=whsec_your-webhook-secret

# Dodo Payments Product IDs (Create these in Dodo dashboard)
# Option 1: Monthly Subscription - ₹850/month for 5M tokens (usage-based, resets monthly)
DODO_PRODUCT_MONTHLY_5M=prod_monthly_5m_subscription_id

# Option 2: Pay-As-You-Go - ₹100 per 500K tokens (flexible, buy any multiple)
# Users can adjust: 1x=500K, 2x=1M, 5x=2.5M, 10x=5M, 20x=10M tokens
DODO_PRODUCT_PAYG=prod_payg_flexible_tokens_id

# Dodo Payments Meter ID (For usage-based billing tracking)
DODO_METER_TOKEN_USAGE=meter_token_usage

# AI Services
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# TinyFish Web Agent API
TINYFISH_API_KEY=tf_xxxxxxxxxxxxxxxxxxxx
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_EXECUTE_PATH=/v1/automation/run-sse
TINYFISH_TIMEOUT_SECONDS=90
# Optional: only if your TinyFish account uses workspaces
# TINYFISH_WORKSPACE_ID=workspace_xxxxx

# Monitoring - Sentry (Optional)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Background Tasks
MAX_BACKGROUND_WORKERS=10

# ==============================================
# Development Overrides (for local development)
# ==============================================
# Uncomment these for local development:
# ENVIRONMENT=development
# DEBUG=True
# BACKEND_URL=http://localhost:8000
# FRONTEND_PLATFORM_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# RATE_LIMIT_ENABLED=False
