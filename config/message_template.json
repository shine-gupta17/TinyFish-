# button message type
{
  "recipient": {
    "id": "1234567890"
  },
  "message": {
    "attachment": {
      "type": "template",
      "payload": {
        "template_type": "button",
        "text": "Hi Rohit! Click the button below to view your booking:",
        "buttons": [
          {
            "type": "web_url",
            "url": "https://yourhotelbooking.com/confirmation?id=1234",
            "title": "View Booking"
          }
        ]
      }
    }
  },
  "messaging_type": "RESPONSE"
}



