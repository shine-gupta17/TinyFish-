# ChatVerse Backend Environment Configuration Template
# Copy this file to .env and fill in your values

# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
DEBUG=false

# ========================================
# Session Security
# ========================================
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=change-this-to-a-secure-random-key

# ========================================
# Database - Supabase
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========================================
# Social Media - Instagram
# ========================================
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# ========================================
# Social Media - Facebook
# ========================================
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# ========================================
# AI Services
# ========================================
OPENAI_API_KEY=your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key

# ========================================
# TinyFish Web Agent API
# ========================================
TINYFISH_API_KEY=your-tinyfish-api-key
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_EXECUTE_PATH=/v1/automation/run-sse
TINYFISH_TIMEOUT_SECONDS=90
# TINYFISH_WORKSPACE_ID=your-workspace-id

# ========================================
# Cloud Storage - AWS S3 Compatible
# ========================================
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_ENDPOINT_URL=https://your-s3-endpoint.com
S3_REGION=us-east-1
CHAT_BUCKET_NAME=chatrag

# ========================================
# Vector Database
# ========================================
PINECONE_CHAT_INDEX=chatrag

# ========================================
# Frontend & Backend URLs
# ========================================
FRONTEND_PLATFORM_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ========================================
# CORS Configuration
# ========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://chatverses.web.app,https://chatverse.io

# ========================================
# Payment Integration - Razorpay
# ========================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_SECRET=your-razorpay-secret

# ========================================
# Payment Integration - Dodo Payments
# ========================================
# Add Dodo Payments credentials if needed

# ========================================
# Monitoring & Analytics (Optional)
# ========================================
# SENTRY_DSN=your-sentry-dsn
# ENVIRONMENT=production

# ========================================
# Twitter/X Integration (Optional)
# ========================================
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret

# ========================================
# Google Services (Optional)
# ========================================
# Configure in credentials/ directory
# GOOGLE_APPLICATION_CREDENTIALS=credentials/google-service-account.json

# ========================================
# LinkedIn Integration (Optional)
# ========================================
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
